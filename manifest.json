{
  "id": "com.xxkotfejxx.typehelper",
  "name": "TypeHelper",
  "version": "0.0.2",
  "manifestVersion": 5,
  "main": "index.html",

  "host": [
    { "app": "PS", "minVersion": "26.11.0" }
  ],

  "entrypoints": [
    {
      "type": "panel",
      "id": "mainPanel",
      "label": "TypeHelper",
      "mainPath": "index.html",
      "minimumSize": { "width": 600, "height": 850 },
      "preferredDockedSize": { "width": 600, "height": 700 }
    }
  ],

  "icons": [
    {
      "width": 32,
      "height": 32,
      "path": "images/icon@1x.png",
      "theme": ["dark", "darkest"]
    },
    {
      "width": 32,
      "height": 32,
      "path": "images/icon@2x.png",
      "theme": ["light", "lightest"]
    }
  ],

  "resources": {
    "index.html": { "type": "html" },
    "index.js": { "type": "javascript" },
    "uxp/js/ui.js": { "type": "javascript" },
    "uxp/js/api.js": { "type": "javascript" }
  },

  "requiredPermissions": {
  "network": {
    "domains": ["localhost:10854", "127.0.0.1:10854"]
  },
  "localFileSystem": "fullAccess",
  "allowPlugins": true
}





}
